# Server-side only — restart dev server after changes

# AI (ATS, chat, skill gap)
GROQ_API_KEY=gsk_your_key_here

# REQUIRED for real LinkedIn job links (Google Jobs / LinkedIn apply URLs)
# Free tier: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch → Subscribe → copy X-RapidAPI-Key
RAPIDAPI_KEY=your_rapidapi_key_here

# Real jobs in Egypt (Careerjet partner — free signup)
# https://www.careerjet.com.eg/partners → affiliate ID (affid) + API key for Basic Auth
CAREERJET_AFFID=your_careerjet_affiliate_id
CAREERJET_API_KEY=your_careerjet_api_key

# Optional — Referer header for Careerjet v4 API
APP_URL=http://localhost:8080/jobs
